{
    "name": "kpirnie/kpt-utils",
    "description": "",
    "type": "library",
    "keywords": [
    ],
    "homepage": "https://github.com/kpirnie/kp-php-utils",
    "license": "MIT",
    "funding": [
        {
            "type": "paypal",
            "url": "https://www.paypal.biz/kevinpirnie"
        },
        {
            "type": "ko-fi",
            "url": "https://ko-fi.com/kevinpirnie"
        }
    ],
    "authors": [
        {
            "name": "Kevin Pirnie",
            "email": "me@kpirnie.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "KPT\\": "src/"
        },
        "classmap": [
            "src/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "KPT\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "scripts": {
        "cs-check": "phpcs src --standard=PSR12",
        "cs-fix": "phpcbf src --standard=PSR12",
        "quality": [
            "@cs-check",
            "@test"
        ]
    },
    "support": {
        "issues": "https://github.com/kpirnie/kp-php-utils/issues",
        "source": "https://github.com/kpirnie/kp-php-utils",
        "docs": "https://github.com/kpirnie/kp-php-utils/blob/main/README.md"
    }
}